{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "py \"${CLAUDE_PLUGIN_ROOT}/hooks/learning-signal-hook.py\"",
            "timeout": 3
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "py \"${CLAUDE_PLUGIN_ROOT}/hooks/outcome-tracker-hook.py\"",
            "timeout": 3
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "py \"${CLAUDE_PLUGIN_ROOT}/hooks/playbook-init-hook.py\"",
            "timeout": 3
          }
        ]
      }
    ]
  }
}
